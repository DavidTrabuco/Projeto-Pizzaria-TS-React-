# Normaliza todos os arquivos de texto para LF ao commitar
* text=auto eol=lf

# Arquivos explicitamente de texto
*.ts   text eol=lf
*.tsx  text eol=lf
*.js   text eol=lf
*.jsx  text eol=lf
*.json text eol=lf
*.css  text eol=lf
*.html text eol=lf
*.md   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.env  text eol=lf

# Binários — não tocar nas quebras de linha
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.svg  binary
